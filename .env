MCP_PORT=8000
CE_PORT=8001
BUSINESS_AGENT_PORT=8002
CUSTOMERS_AGENT_PORT=8003
HR_AGENT_PORT=8004
MCP_HOST=mcp

LLM_PROVIDER=ollama #ollama   # ollama or openai
LLM_MODEL=llama3.1 # gpt-oss:20b for ollama, gpt-4o-mini for openai
JUDGE_LLM_PROVIDER=ollama # dedicated provider for evaluation judge
JUDGE_LLM_MODEL=llama3.1 # dedicated model for evaluation judge
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OLLAMA_URL=http://host.docker.internal:11434
TRAINED_MODELS_PATH=/app/models

AUTONOMOUS_MODE=true
